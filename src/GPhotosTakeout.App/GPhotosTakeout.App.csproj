<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>GPhotosTakeout.App</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>

    <!-- Packaging model:
         * default (no Packaging prop)  → unpackaged, self-contained, full file-system
           trust, can launch ExifTool. This is the proven dev/run build used by CI.
         * -p:Packaging=true            → MSIX (Store) build, full-trust desktop app
           (runFullTrust, NOT sandboxed), so ExifTool + file access still work.
         Both are self-contained so the WinAppSDK runtime ships with the app. -->
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <WindowsPackageType Condition="'$(Packaging)' == 'true'">MSIX</WindowsPackageType>
    <WindowsPackageType Condition="'$(Packaging)' != 'true'">None</WindowsPackageType>
    <EnableMsixTooling Condition="'$(Packaging)' == 'true'">true</EnableMsixTooling>
    <EnableMsixTooling Condition="'$(Packaging)' != 'true'">false</EnableMsixTooling>
    <GenerateAppxPackageOnBuild Condition="'$(Packaging)' == 'true'">true</GenerateAppxPackageOnBuild>
    <AppxPackageSigningEnabled Condition="'$(Packaging)' == 'true'">false</AppxPackageSigningEnabled>
    <AppxBundle Condition="'$(Packaging)' == 'true'">Never</AppxBundle>

    <!-- MVVMTK0045 advises partial properties for AOT/WinRT marshalling. We ship a
         JIT self-contained app (not AOT), so the field form is correct and safe. -->
    <NoWarn>$(NoWarn);MVVMTK0045</NoWarn>
  </PropertyGroup>

  <!-- Single-file EXE publish (opt-in via -p:PublishSingleFile=true). Produces ONE
       self-contained .exe so users download a single file instead of a zip — deps
       self-extract to a temp dir on first launch. WinUI 3 requires the unpackaged +
       self-contained model with EnableMsixTooling + IncludeAllContentForSelfExtract;
       see https://learn.microsoft.com/windows/apps/package-and-deploy/unpackage-winui-app#single-file-exe
       (Because BaseDirectory is then a temp dir, ExifTool installs to LocalAppData —
       see ExifToolInstaller.) Guarded so a plain `dotnet build` stays unaffected. -->
  <PropertyGroup Condition="'$(PublishSingleFile)' == 'true'">
    <SelfContained>true</SelfContained>
    <EnableMsixTooling>true</EnableMsixTooling>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <!-- Embed symbols so the publish output is a single artifact (no loose .pdb). -->
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.2.0" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4948" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GPhotosTakeout.Core\GPhotosTakeout.Core.csproj" />
  </ItemGroup>

  <!-- Ship the Tools folder (drop exiftool.exe here) next to the app. -->
  <ItemGroup>
    <None Include="Tools\**" CopyToOutputDirectory="PreserveNewest" LinkBase="Tools" />
  </ItemGroup>

  <!-- MSIX-only: the package manifest and Store logos (opt-in via -p:Packaging=true so
       the default unpackaged build is unaffected). -->
  <ItemGroup Condition="'$(Packaging)' == 'true'">
    <AppxManifest Include="Package.appxmanifest">
      <SubType>Designer</SubType>
    </AppxManifest>
    <Content Include="Assets\*.png" />
  </ItemGroup>

</Project>
